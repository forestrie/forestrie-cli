{
  "name": "@forestrie/forestrie-cli",
  "version": "0.3.2",
  "private": true,
  "description": "forestrie — single-binary participant CLI for forestrie transparency logs",
  "type": "module",
  "bin": {
    "forestrie": "./dist/cli.js"
  },
  "scripts": {
    "dev": "bun run ./src/cli.ts",
    "build": "bun build ./src/cli.ts --outdir dist --target bun",
    "build:binary": "bun scripts/build-binary.ts",
    "build:binary:linux-x64": "bun scripts/build-binary.ts --target bun-linux-x64",
    "build:binary:darwin-arm64": "bun scripts/build-binary.ts --target bun-darwin-arm64",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@forestrie/chain-rpc": "^0.1.1",
    "@forestrie/cli-kit": "^0.1.0",
    "@forestrie/delegation-cose": "^0.1.5",
    "@forestrie/deploy-core": "^0.6.0",
    "@forestrie/encoding": "^0.5.0",
    "@forestrie/grant-builder": "^0.2.1",
    "@forestrie/merklelog": "^0.1.1",
    "@forestrie/receipt-verify": "^0.6.3",
    "@forestrie/scrapi-client": "^0.1.3",
    "citty": "^0.2.2",
    "viem": "^2.31.0"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.9.2"
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}
